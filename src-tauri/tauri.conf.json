{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoBird",
  "version": "5.0.7",
  "identifier": "com.echobird.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite --host",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EchoBird",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "EchoBird Team",
    "copyright": "(c) 2026 EchoBird Team",
    "shortDescription": "The Nexus for Models, Agents & Vibe Coding",
    "longDescription": "EchoBird - The Nexus for Models, Agents & Vibe Coding. One hub to manage AI models, coding tools, and intelligent agents.",
    "homepage": "https://echobird.ai/",
    "category": "DeveloperTool",
    "resources": ["../tools/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "installer.nsi",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "EchoBird"
      }
    }
  }
}
